{
  "name": "@jgoon/bluebubbles",
  "version": "1.0.0",
  "description": "Type-safe TypeScript client for the BlueBubbles Server API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./schema": {
      "types": "./src/schema.d.ts"
    }
  },
  "files": [
    "dist",
    "src/schema.d.ts"
  ],
  "scripts": {
    "generate": "openapi-typescript ../../openapi.yaml -o src/schema.d.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BlueBubblesApp/bluebubbles-sdk.git",
    "directory": "sdks/typescript"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
